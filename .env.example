# Database Configuration
POSTGRES_USER=filadex
POSTGRES_PASSWORD=filadex
POSTGRES_DB=filadex
PGHOST=db
PGPORT=5432

# Application Configuration
APP_PORT=8080
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARN, ERROR

# Secret used to sign login sessions (JWT). Set this to a long random string
# (e.g. `openssl rand -hex 32`) so sessions survive container restarts.
# If unset, a random secret is generated on each startup and all users are logged out on restart.
JWT_SECRET=

# Set to "true" only if this instance runs behind a trusted reverse proxy
# (e.g. Traefik/Nginx in a SaaS deployment). This makes rate limiting and
# logging use the real client IP from X-Forwarded-For instead of the proxy's.
# Do NOT set this if the app is reachable directly - it would let clients
# spoof their IP and bypass rate limiting.
TRUST_PROXY=false

# Admin User Configuration
ADMIN_PASSWORD=admin
